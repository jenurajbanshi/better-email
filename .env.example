# ---------------------------------------------------------------------------
# better-email configuration. Copy to `.env` and fill in. NEVER commit `.env`.
# On Railway / cloud hosts, set these as project variables/secrets instead.
# ---------------------------------------------------------------------------

# Runtime environment: "dev" | "prod". In "prod" an insecure SECRET_KEY is rejected.
APP_ENV=dev

# Database. SQLite by default (local/demo). On Railway, add a Postgres plugin and
# Railway injects DATABASE_URL automatically (postgresql+psycopg://...).
DATABASE_URL=sqlite:///./better_email.db

# Used to encrypt connector credentials/tokens at rest and sign sessions.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=dev-only-insecure-change-me

# API access token for the single-owner gate (v1). Generate a strong value.
# The bootstrap owner is created on first run with this key.
OWNER_API_KEY=dev-owner-key-change-me
OWNER_EMAIL=owner@example.com

# CORS: comma-separated list of allowed frontend origins. Never use "*".
CORS_ORIGINS=http://localhost:5173

# ----------------------------- LLM provider --------------------------------
# Provider: "mock" (offline, default) | "openai" | "anthropic" | "ollama"
LLM_PROVIDER=mock
LLM_MODEL=mock-small

# Only needed for the corresponding provider:
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Redact PII before sending any text to the LLM (recommended: true).
LLM_REDACT_PII=true

# ----------------------------- Connector -----------------------------------
# Default connector: "mock" (offline seed data) | "gmail"
CONNECTOR=mock

# Gmail OAuth (only needed when CONNECTOR=gmail). Configure least-privilege scopes.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8000/api/connectors/gmail/callback

# ----------------------------- Triage --------------------------------------
# A request awaiting our reply older than this many hours is "forgotten".
FORGOTTEN_AFTER_HOURS=24
